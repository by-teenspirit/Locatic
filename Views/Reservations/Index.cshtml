@model IEnumerable<Locatic.Entities.Reservation>

@{
    ViewData["Title"] = "Gestion des Réservations";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Réservations en cours</h1>
    <a asp-action="Create" class="btn btn-primary">Nouvelle Location</a>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Client</th>
                <th>Véhicule</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Durée</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                // Petit calcul rapide pour l'affichage de la durée
                var duree = (item.DateFin - item.DateDebut).Days;
                
                <tr>
                    <td><strong>@item.Client.Nom @item.Client.Prenom</strong></td>
                    <td>
                        <span class="text-primary fw-bold">@item.Voiture.Modele.Marque.Nom @item.Voiture.Modele.Nom</span><br/>
                        <small class="text-muted">@item.Voiture.Immatriculation</small>
                    </td>
                    <td>@item.DateDebut.ToString("dd/MM/yyyy")</td>
                    <td>@item.DateFin.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge bg-info text-dark">@duree jours</span></td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-5">Aucune réservation enregistrée.</td>
                </tr>
            }
        </tbody>
    </table>
</div>