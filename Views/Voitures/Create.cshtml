@model Locatic.Models.VoitureFormViewModel

@{
    ViewData["Title"] = "Ajouter une voiture";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Ajouter un nouveau véhicule</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="SelectedModeleId" class="form-label">Marque & Modèle</label>
                        <select asp-for="SelectedModeleId" asp-items="Model.Modeles" class="form-select">
                            <option value="">-- Sélectionner un modèle --</option>
                        </select>
                        <span asp-validation-for="SelectedModeleId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Immatriculation" class="form-label">Immatriculation (Ex: AA-123-AA)</label>
                        <input asp-for="Immatriculation" class="form-control" placeholder="AA-123-AA" />
                        <span asp-validation-for="Immatriculation" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Annee" class="form-label">Année</label>
                            <input asp-for="Annee" type="number" class="form-control" />
                            <span asp-validation-for="Annee" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TarifJournalier" class="form-label">Tarif par jour (€)</label>
                            <input asp-for="TarifJournalier" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="TarifJournalier" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NbrPlaces" class="form-label">Nombre de places</label>
                            <input asp-for="NbrPlaces" type="number" class="form-control" />
                            <span asp-validation-for="NbrPlaces" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Carburant" class="form-label">Carburant</label>
                            <select asp-for="Carburant" class="form-select">
                                <option value="">-- Choisir --</option>
                                <option value="Essence">Essence</option>
                                <option value="Diesel">Diesel</option>
                                <option value="Électrique">Électrique</option>
                                <option value="Hybride">Hybride</option>
                            </select>
                            <span asp-validation-for="Carburant" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Retour à la liste</a>
                        <button type="submit" class="btn btn-success">Enregistrer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}