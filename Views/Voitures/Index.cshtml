@model IEnumerable<Locatic.Entities.Voiture>

@{
    ViewData["Title"] = "Parc Automobile";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Notre Parc Automobile</h1>
    <a asp-action="Create" class="btn btn-primary">Ajouter une voiture</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Marque</th>
            <th>Modèle</th>
            <th>Immatriculation</th>
            <th>Carburant</th>
            <th>Places</th>
            <th>Tarif Journalier</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Modele.Marque.Nom</strong></td>
                <td>@item.Modele.Nom</td>
                <td><span class="badge bg-secondary font-monospace fs-6">@item.Immatriculation</span></td>
                <td>@item.Carburant</td>
                <td>@item.NbrPlaces</td>
                <td>@item.TarifJournalier.ToString("C")</td> </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">Aucune voiture disponible dans le parc.</td>
            </tr>
        }
    </tbody>
</table>