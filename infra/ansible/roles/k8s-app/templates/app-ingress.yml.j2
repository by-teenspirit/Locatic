apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: locatic-ingress
  namespace: {{ k8s_namespace }}
spec:
  ingressClassName: nginx
  rules:
    - host: locatic.local 
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: locatic-app-service
                port:
                  number: 3000